<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Test Run Report — {{ task_id }}</title>
<style>
  :root {
    --bg: #fff;
    --fg: #24292f;
    --muted: #656d76;
    --border: #d0d7de;
    --bg-subtle: #f6f8fa;
    --accent: #0969da;
    --success: #1a7f37;
    --fail: #cf222e;
  }
  *, *::before, *::after { box-sizing: border-box; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica,
                 Arial, sans-serif;
    line-height: 1.6;
    color: var(--fg);
    background: var(--bg);
    max-width: 960px;
    margin: 0 auto;
    padding: 2rem 1.5rem;
  }
  h1 { font-size: 1.75rem; border-bottom: 1px solid var(--border); padding-bottom: .4em; }
  h2 { font-size: 1.35rem; margin-top: 2rem; border-bottom: 1px solid var(--border); padding-bottom: .3em; }
  h3 { font-size: 1.1rem; margin-top: 1.5rem; }
  code {
    background: var(--bg-subtle);
    padding: .15em .35em;
    border-radius: 4px;
    font-size: .9em;
  }
  .meta-table { width: 100%; border-collapse: collapse; margin: .5rem 0 1rem; }
  .meta-table td { padding: .35rem .6rem; border: 1px solid var(--border); }
  .meta-table td:first-child { font-weight: 600; width: 140px; background: var(--bg-subtle); }

  .status-completed { color: var(--success); font-weight: 600; }
  .status-failed { color: var(--fail); font-weight: 600; }

  .screenshot-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: .75rem;
    margin: .75rem 0;
  }
  .screenshot-grid figure { margin: 0; text-align: center; }
  .screenshot-grid figcaption { font-size: .85rem; color: var(--muted); margin-top: .3rem; }
  .screenshot-grid img, .screenshot-single img {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--border);
    border-radius: 6px;
  }
  .screenshot-single { margin: .75rem 0; }
  .screenshot-single figcaption { font-size: .85rem; color: var(--muted); margin-top: .3rem; }

  blockquote {
    margin: .5rem 0;
    padding: .5rem 1rem;
    border-left: 3px solid var(--border);
    background: var(--bg-subtle);
    white-space: pre-wrap;
    font-size: .9rem;
  }

  .errors { color: var(--fail); }
  .errors li { margin-bottom: .25rem; }

  .telemetry-table { width: 100%; border-collapse: collapse; margin: .5rem 0; }
  .telemetry-table th, .telemetry-table td {
    padding: .35rem .6rem;
    border: 1px solid var(--border);
    text-align: left;
    font-size: .9rem;
  }
  .telemetry-table th { background: var(--bg-subtle); font-weight: 600; }
</style>
</head>
<body>

{% if task_name %}
<h1>Test Report: {{ task_name }}</h1>
{% else %}
<h1>Test Report</h1>
{% endif %}

<h2>General Information</h2>
<table class="meta-table">
  <tr><td>Task ID</td><td><code>{{ task_id }}</code></td></tr>
  {% if task_name %}
  <tr><td>Task Name</td><td>{{ task_name }}</td></tr>
  {% endif %}
  {% if instruction %}
  <tr><td>Instruction</td><td>{{ instruction | e | replace('\n', '<br/>' | safe) }}</td></tr>
  {% endif %}
  {% if device_id %}
  <tr><td>Device ID</td><td>{{ device_id }}</td></tr>
  {% endif %}
  {% if precondition_groups %}
  <tr><td>Preconditions</td><td>
    {% for group in precondition_groups %}<code>{{ group.label }}</code>{% if not loop.last %}, {% endif %}{% endfor %}
  </td></tr>
  {% endif %}
  <tr><td>Status</td><td class="status-{{ status }}">{{ status }}</td></tr>
  {%- if reason %}
  <tr><td>Reason</td><td>{{ reason }}</td></tr>
  {%- endif %}
  <tr><td>Duration (total)</td><td>{{ total_duration_fmt }}</td></tr>
  {% if precondition_duration_fmt %}
  <tr><td>Duration (precondition)</td><td>{{ precondition_duration_fmt }}</td></tr>
  {% endif %}
  <tr><td>Duration (test)</td><td>{{ test_duration_fmt }}</td></tr>
  <tr><td>Started</td><td>{{ start_ts }}</td></tr>
  <tr><td>Total Steps</td><td>{{ steps | length }}</td></tr>
</table>

{% macro render_step(rec) %}
<h4>Step {{ rec.step }}</h4>

{% if rec.screenshots | length == 2 %}
<div class="screenshot-grid">
  {% for src, desc in rec.screenshots %}
  <figure>
    <img src="{{ src }}" alt="{{ desc }}" loading="lazy">
    <figcaption>{{ desc | screenshot_label }}</figcaption>
  </figure>
  {% endfor %}
</div>
{% elif rec.screenshots %}
  {% for src, desc in rec.screenshots %}
  <figure class="screenshot-single">
    <img src="{{ src }}" alt="{{ desc }}" loading="lazy">
    <figcaption>{{ desc | screenshot_label }}</figcaption>
  </figure>
  {% endfor %}
{% endif %}

{% if rec.operator %}
<strong>Operator</strong>
<blockquote>{{ rec.operator }}</blockquote>
{% endif %}

{% if rec.action_result %}
<strong>Action Result</strong>
<blockquote>{{ rec.action_result }}</blockquote>
{% endif %}

{% if rec.reflector %}
<strong>Reflector</strong>
<blockquote>{{ rec.reflector }}</blockquote>
{% endif %}

{% if rec.errors %}
<strong>Errors</strong>
<ul class="errors">
  {% for err in rec.errors %}
  <li>{{ err }}</li>
  {% endfor %}
</ul>
{% endif %}
{% endmacro %}

{% if precondition_groups %}
<h2>Preconditions</h2>
{% for group in precondition_groups %}
{% if group.current_step %}
<h3>{{ group.current_step }}</h3>
{% endif %}
<p>Label: <code>{{ group.label }}</code></p>
{% for rec in group.steps %}
{{ render_step(rec) }}
{% endfor %}
{% endfor %}
{% endif %}

<h2>Test Steps</h2>
{% for group in step_groups %}
{% if group.current_step %}
<h3>{{ group.current_step }}</h3>
{% endif %}
{% for rec in group.steps %}
{{ render_step(rec) }}
{% endfor %}
{% endfor %}

{% if telemetry %}
<h2>Telemetry</h2>
<table class="telemetry-table">
  <tr><th>Metric</th><th>Details</th></tr>
  {% for key, value in telemetry.items() %}
  <tr><td>{{ key }}</td><td>{{ value | fmt_telemetry }}</td></tr>
  {% endfor %}
</table>
{% endif %}

</body>
</html>
