{
  "name": "@sico/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "dev": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "lint": "npm run lint:tsc && npm run lint:oxlint && npm run lint:eslint:fix && npm run lint:fmt:fix",
    "lint:tsc": "tsgo --noEmit --incremental --tsBuildInfoFile node_modules/.cache/tsgo/.tsbuildinfo",
    "lint:oxlint": "oxlint -c ../../packages/config/.oxlintrc.json --disable-nested-config --type-aware --max-warnings 0",
    "lint:eslint": "eslint . --cache --cache-location node_modules/.cache/eslint/ --max-warnings 0 --concurrency auto",
    "lint:eslint:fix": "npm run lint:eslint -- --fix",
    "lint:fmt": "oxfmt --config ../../packages/config/.oxfmtrc.json --check .",
    "lint:fmt:fix": "oxfmt --config ../../packages/config/.oxfmtrc.json .",
    "test": "vitest run --silent=true",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@sico/config": "workspace:*",
    "@storybook/addon-docs": "^9.1.20",
    "@storybook/react-vite": "^9.1.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "axios-mock-adapter": "^2.1.0",
    "msw": "^2.14.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "storybook": "^9.1.20"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@babylonjs/loaders": "^9.13.0",
    "@babylonjs/viewer": "^9.13.0",
    "@codemirror/lang-css": "6.3.1",
    "@codemirror/lang-html": "6.4.11",
    "@codemirror/lang-javascript": "6.2.5",
    "@codemirror/lang-json": "6.0.2",
    "@codemirror/lang-markdown": "6.5.0",
    "@codemirror/lang-python": "6.2.1",
    "@codemirror/lang-xml": "6.1.0",
    "@codemirror/lang-yaml": "6.1.3",
    "@hookform/resolvers": "^5.4.0",
    "@microsoft/fetch-event-source": "^2.0.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@sico/ui": "workspace:*",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.2",
    "@uiw/react-codemirror": "4.25.10",
    "axios": "^1.16.0",
    "fflate": "0.8.3",
    "immer": "^11.1.8",
    "jotai": "^2.20.0",
    "lucide-react": "^1.11.0",
    "pdfjs-dist": "^6.0.227",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.76.1",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.6.6",
    "remark-gfm": "^4.0.1",
    "use-stick-to-bottom": "^1.1.6",
    "zod": "^4.4.3"
  }
}
