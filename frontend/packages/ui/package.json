{
  "name": "@sico/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "dev": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "npm run lint:tsc && npm run lint:oxlint && npm run lint:eslint:fix && npm run lint:fmt:fix",
    "lint:tsc": "tsgo --noEmit --incremental --tsBuildInfoFile node_modules/.cache/tsgo/.tsbuildinfo",
    "lint:oxlint": "oxlint -c ../../packages/config/.oxlintrc.json --disable-nested-config --type-aware --max-warnings 0",
    "lint:eslint": "eslint . --cache --cache-location node_modules/.cache/eslint/ --max-warnings 0 --concurrency auto",
    "lint:eslint:fix": "npm run lint:eslint -- --fix",
    "lint:fmt": "oxfmt --config ../../packages/config/.oxfmtrc.json --check .",
    "lint:fmt:fix": "oxfmt --config ../../packages/config/.oxfmtrc.json .",
    "test": "vitest run --silent=true",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lottie-react": "2.4.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "@base-ui/react": "^1.4.1",
    "@tabler/icons-react": "^3.44.0",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.4.1",
    "@sico/config": "workspace:*",
    "@storybook/addon-a11y": "^9.1.8",
    "@storybook/addon-docs": "^9.1.8",
    "@storybook/addon-themes": "^9.1.8",
    "@storybook/react-vite": "^9.1.8",
    "@tabler/icons-react": "^3.44.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.4.0",
    "storybook": "^9.1.8",
    "storybook-addon-rtl": "^2.0.1",
    "storybook-design-token": "4.1.0",
    "tw-animate-css": "^1.4.0"
  }
}
